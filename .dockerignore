# Dependencies and build output (rebuilt inside the image)
node_modules
build
dist
*.tsbuildinfo

# Version control and CI
.git
.gitignore
.github

# Editor / OS cruft
.vscode
.idea
.DS_Store
*.swp

# Docs and planning — not needed to build or run
*.md
docs

