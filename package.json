{
  "name": "tie-mcp-server",
  "version": "0.3.0",
  "description": "MCP server for Tenable Identity Exposure API",
  "main": "build/index.js",
  "type": "module",
  "bin": {
    "tie-mcp-server": "build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsx src/index.ts",
    "generate:client": "openapi-typescript identity-exposure-openapi.json -o src/generated/api-types.ts",
    "generate:tools": "node scripts/generate-tools.mjs",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tenable",
    "identity-exposure",
    "security",
    "active-directory"
  ],
  "author": "taherkaraki <mtaher@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taherkaraki/tie-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/taherkaraki/tie-mcp-server/issues"
  },
  "homepage": "https://github.com/taherkaraki/tie-mcp-server#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.17.0",
    "openapi-typescript": "^7.4.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
